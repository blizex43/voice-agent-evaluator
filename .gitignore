output/recordings/*
output/reports/*
output/transcripts/*
!output/recordings/.gitkeep
!output/reports/.gitkeep
!output/transcripts/.gitkeep

# Logs and temporary files
*.log
*.tmp
*.bak
tmp/
temp/

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Twilio/ngrok local state
.ngrok/
ngrok.yml
