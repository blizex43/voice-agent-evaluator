# Environment and secrets
.env
.env.*
!.env.example

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments
venv/
.venv/
env/
ENV/

